include "geometry.fbs";
include "primitives.fbs";

namespace slamd.flatb;

table ChildEntry {
    key: string;
    value: Node;
}

table Node {
    transform: Mat4;
    // 0 means no geometry is associated
    geometry_id: ulong = 0;
    children: [ChildEntry];
}

table Tree {
    id: ulong;
    root: Node;
}

table View {
    name: string;
    tree_id: ulong;
}

table InitialState {
    name: string;
    views: [View];
    trees: [Tree];
    geometries: [Geometry];
}

root_type InitialState;