include "primitives.fbs";

namespace slamd.flatb;

table Triad {
    scale: float;
    thickness: float;
    pose: Mat4;
}

table CameraFrustum {
    intrinsics: Mat3;
    image_width: uint32;
    image_height: uint32;
    scale: float;
    image: ImageData;
}

table PointCloud {
    positions: [Vec3];
    colors: [Vec3];
    radii: [float];
    min_brightness: float;
}

table Image {
    img: ImageData;
    normalized: bool;
}

table Box {}

table Sphere {
    radius: float;
    color: Vec3;
}

table Arrows {
    starts: [Vec3];
    ends: [Vec3];
    colors: [Vec3];
    thickness: float;
}

table PolyLine {
    points: [Vec3];
    thickness: float;
    color: Vec3;
    min_brightness: float;
}

table Mesh {
    data: MeshData;
    min_brightness: float;
}

table Spheres {
    positions: [Vec3];
    colors: [Vec3];
    radii: [float];
    min_brightness: float;
}

table Plane {
    normal: Vec3;
    point: Vec3;
    color: Vec3;
    radius: float;
    alpha: float;
}

union GeometryUnion {
    triad: Triad,
    camera_frustum: CameraFrustum,
    point_cloud: PointCloud,
    image: Image,
    box: Box,
    sphere: Sphere,
    arrows: Arrows,
    poly_line: PolyLine,
    mesh: Mesh,
    plane: Plane,
    spheres: Spheres
}

table Geometry {
    geometry_id: ulong;
    geometry: GeometryUnion;
}

